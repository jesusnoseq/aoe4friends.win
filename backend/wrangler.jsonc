{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aoe4friendswin-apiproxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "r2_buckets": [
    { "binding": "SUMMARIES", "bucket_name": "aoe4friends-win-summaries" }
  ],
  "analytics_engine_datasets": [
    { "binding": "USAGE", "dataset": "aoe4friends_usage" }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
